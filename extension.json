{
	"name": "VisualEditorPlus",
	"version": "2.3.0-alpha.1",
	"license-name": "GPL-3.0-only",
	"author": [
		"[http://www.hallowelt.com Hallo Welt! GmbH]"
	],
	"url": "https://en.wiki.bluespice.com/wiki/Reference:VisualEditorPlus",
	"descriptionmsg": "visualeditorplus-desc",
	"requires": {
		"MediaWiki": ">= 1.43.0"
	},
	"attributes": {
		"VisualEditor": {
			"PluginModules":
				[
					"ext.visualEditorPlus.tags",
					"ext.visualEditorPlus",
					"ext.visualEditorPlus.inlineTextInspector",
					"ext.visualEditorPlus.table"
				]
		},
		"CollabPads": {
			"PluginModules": [
				"ext.visualEditorPlus.tags"
			]
		}
	},
	"MessagesDirs": {
		"VisualEditorPlus": "i18n"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\VisualEditorPlus\\": "src/"
	},
	"ResourceModules": {
		"ext.visualEditorPlus.bootstrap": {
			"scripts": [
				"ext.visualEditorPlus.bootstrap.js"
			]
		},
		"ext.visualEditorPlus.registry": {
			"scripts": [
				"ext.visualEditorPlus.registry.js"
			],
			"dependencies": [
				"oojs",
				"ext.visualEditorPlus.bootstrap"
			]
		},
		"ext.visualEditorPlus.inlineTextInspector": {
			"scripts": [
				"ext.visualEditorPlus.inlineTextInspector/InlineTextInspectorElement.js",
				"ext.visualEditorPlus.inlineTextInspector/InlineTextInspector.js",
				"ext.visualEditorPlus.inlineTextInspector/bootstrap.js"
			],
			"styles": [
				"ext.visualEditorPlus.inlineTextInspector/styles.less"
			],
			"dependencies": [
				"ext.visualEditor.core",
				"ext.visualEditorPlus.registry"
			]
		},
		"ext.visualEditorPlus": {
			"scripts": [
				"ext.visualEditorPlus/ui/WrapperSequenceBase.js",
				"ext.visualEditorPlus/ui/BackTickCodeSequence.js",
				"ext.visualEditorPlus/ui/TildeStrikeThroughSequence.js",
				"ext.visualEditorPlus/ui/UnderlineItalicSequence.js",
				"ext.visualEditorPlus.replacementSequences.js",
				"ext.visualEditorPlus.updateVEToolbar.js"
			],
			"dependencies": [
				"ext.visualEditor.core"
			]
		},
		"ext.visualEditorPlus.tags.definition": {
			"scripts": [
				"ext.visualEditorPlus.tags/TagDefinition.js",
				"ext.visualEditorPlus.tags/WrapperDefinition.js"
			],
			"styles": [
				"ext.visualEditorPlus.tags/styles.less"
			],
			"messages": [
				"visualeditorplus-ui-label-unwrap",
				"visualeditorplus-ui-label-delete"
			],
			"dependencies": [
				"ext.visualEditorPlus.bootstrap",
				"oojs"
			]
		},
		"ext.visualEditorPlus.tags": {
			"scripts": [
				"ext.visualEditorPlus.tags/TagRegistry.js",
				"ext.visualEditorPlus.tags.js"
			],
			"dependencies": [
				"ext.visualEditorPlus.bootstrap",
				"ext.visualEditorPlus.tags.definition"
			]
		},
		"ext.visualEditorPlus.tags.wrapperAction": {
			"scripts": [
				"ext.visualEditorPlus.tags/WrapperAction.js"
			]
		},
		"ext.visualEditorPlus.table": {
			"scripts": [
				"ext.visualEditorPlus.table/contextItem/ImprovedTableContextItem.js",
				"ext.visualEditorPlus.table/contextItem/ImprovedTableLineContextItem.js",
				"ext.visualEditorPlus.table/dialog/AdditionalActionsDialog.js"
			],
			"styles": [
				"stylesheets/TableContextItem.css"
			],
			"messages": [
				"cancel",
				"visualeditorplus-table-contextitemwidget-label-remove",
				"visualeditorplus-table-contextitem-properties-label",
				"visualeditorplus-table-contextitem-additional-options-label",
				"visualeditorplus-table-cell-actions-dialog-title",
				"visualeditorplus-table-cell-actions-dialog-done-label"
			]
		},
		"ext.visualEditorPlus.styleInspector": {
			"scripts": [
				"ext.visualEditorPlus.styleInspector/styleTool/ButtonTool.js",
				"ext.visualEditorPlus.styleInspector/styleTool/Bold.js",
				"ext.visualEditorPlus.styleInspector/styleTool/Italic.js",
				"ext.visualEditorPlus.styleInspector/styleTool/Code.js",
				"ext.visualEditorPlus.styleInspector/styleTool/Small.js",
				"ext.visualEditorPlus.styleInspector/styleTool/Big.js",
				"ext.visualEditorPlus.styleInspector/styleTool/Strikethrough.js",
				"ext.visualEditorPlus.styleInspector/styleTool/Underline.js",
				"ext.visualEditorPlus.styleInspector/styleTool/Link.js",
				"ext.visualEditorPlus.styleInspector/TextStyleToolRegistry.js",
				"ext.visualEditorPlus.styleInspector/Inspector.js"
			],
			"dependencies": [
				"oojs-ui",
				"ext.visualEditor.mwcore",
				"ext.visualEditorPlus.inlineTextInspector"
			]
		}
	},
	"callback": "MediaWiki\\Extension\\VisualEditorPlus\\Extension::callback",
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "VisualEditorPlus/resources"
	},
	"Hooks": {
	},
	"manifest_version": 2,
	"load_composer_autoloader": true
}
